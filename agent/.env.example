# Which chain this process serves (one process per chain)
CHAIN=galileo

# Chain-independent agent secrets
AGENT_PRIVATE_KEY=0x...
AGENT_ECIES_PRIVATE_KEY=0x...
STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai
ZG_SERVICE_URL=https://compute-network-6.integratenetwork.work
ZG_API_SECRET=...
# Optional per-chain 0G TEE creds (own budget per chain): <CHAIN>_ZG_SERVICE_URL / <CHAIN>_ZG_API_SECRET, e.g. GALILEO_ZG_SERVICE_URL=...  (falls back to the shared ZG_SERVICE_URL/ZG_API_SECRET)
# Model served by the endpoint. The allotted endpoint is server-pinned to qwen2.5-omni-7b (default).
# When 0G re-provisions us to a bigger model (e.g. 0GM-1.0-35B-A3B) set ZG_MODEL (or <CHAIN>_ZG_MODEL) — no code change.
ZG_MODEL=qwen/qwen2.5-omni-7b

# Per-testnet config. Deploy the mock stack on each (contracts: DEPLOY_MODE=mock,
# npx hardhat run scripts/deploy.ts --network <net>), then set <CHAIN>_VAULT and
# <CHAIN>_USDC to the printed StrategyVault + oUSDC. RPCs have working defaults.

# Galileo (CHAIN=galileo)
GALILEO_RPC=https://evmrpc-testnet.0g.ai
VAULT_ADDRESS=0x...
USDC_ADDRESS=0x...

# Arbitrum Sepolia (CHAIN=arbitrum-sepolia)
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_SEPOLIA_VAULT=0x...
ARBITRUM_SEPOLIA_USDC=0x...

# Base Sepolia (CHAIN=base-sepolia)
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_SEPOLIA_VAULT=0x...
BASE_SEPOLIA_USDC=0x...

# Avalanche Fuji (CHAIN=avalanche-fuji)
FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
FUJI_VAULT=0x...
FUJI_USDC=0x...

# Mantle Sepolia (CHAIN=mantle-sepolia)
MANTLE_SEPOLIA_RPC=https://rpc.sepolia.mantle.xyz
MANTLE_SEPOLIA_VAULT=0x...
MANTLE_SEPOLIA_USDC=0x...

# Ethereum Sepolia (CHAIN=sepolia) - real Uniswap V3, settles in real USDC (6dec)
SEPOLIA_RPC=https://sepolia.drpc.org
SEPOLIA_VAULT=0x...
SEPOLIA_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# Sui testnet agent (npm run start:sui). Object ids from `sui client publish` + setup.
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_PACKAGE_ID=0x...
# SUI_EVENTS_PKG defaults to the ORIGINAL published package id; set only after a package
# upgrade (event/struct types keep the original id, so event queries must use it).
# SUI_EVENTS_PKG=0x...
SUI_VAULT_ID=0x...
SUI_ORACLE_ID=0x...
SUI_AGENT_CAP_ID=0x...
# Sui signer (holds AgentCap, pays gas). bech32 suiprivkey1..., 0x hex, or base64.
# SUI_ATTESTOR_PRIVATE_KEY defaults to this key; its pubkey must equal vault.attestor.
SUI_PRIVATE_KEY=suiprivkey1...
# SUI_ATTESTOR_PRIVATE_KEY=suiprivkey1...
# DeepBook v3 swap venue (real liquidity). All default to the live testnet deployment;
# override only if the protocol moves. Buy DEEP for swap fees once via `npm run deep:acquire`.
# DEEPBOOK_PKG=0x...
# DEEPBOOK_SUI_DBUSDC_POOL=0x...
# DEEPBOOK_DEEP_SUI_POOL=0x...
# DEEPBOOK_DBUSDC_TYPE=0x...::DBUSDC::DBUSDC
# DEEPBOOK_DEEP_TYPE=0x...::deep::DEEP
# DEEPBOOK_FEE_DEEP_UNITS=100000
